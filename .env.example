# AI Job Application Agent - Environment Variables

# --- AI Configuration ---
JOB_AGENT_AI__USE_AI=true
JOB_AGENT_AI__PROVIDER=groq
JOB_AGENT_AI__GROQ_API_KEY=gsk_your_groq_api_key_here
JOB_AGENT_AI__GROQ_MODEL=deepseek-r1-distill-llama-70b
JOB_AGENT_AI__OPENAI_API_KEY=
JOB_AGENT_AI__OPENAI_MODEL=gpt-4o

# --- Personal Info ---
JOB_AGENT_PERSONAL__FIRST_NAME=Shubham
JOB_AGENT_PERSONAL__LAST_NAME=Kambli
JOB_AGENT_PERSONAL__EMAIL=notshuubham11@gmail.com
JOB_AGENT_PERSONAL__PHONE_NUMBER=
JOB_AGENT_PERSONAL__CURRENT_CITY=India

# --- Search ---
JOB_AGENT_SEARCH__SEARCH_TERMS=["AI Engineer","Full Stack Developer","Founding Engineer"]
JOB_AGENT_SEARCH__REMOTE_ONLY=true
JOB_AGENT_SEARCH__EASY_APPLY_ONLY=true
JOB_AGENT_SEARCH__PLATFORMS=["linkedin","yc_jobs"]

# --- Resume ---
JOB_AGENT_RESUME__DEFAULT_RESUME_PATH=all resumes/default/resume.pdf
JOB_AGENT_RESUME__YEARS_OF_EXPERIENCE=1

# --- Ranking ---
JOB_AGENT_RANKING__MIN_SCORE_THRESHOLD=60
JOB_AGENT_RANKING__CONFIDENCE_THRESHOLD=0.7

# --- Database ---
JOB_AGENT_DATABASE__URL=sqlite:///data/job_applications.db

# --- Google Sheets Dashboard ---
JOB_AGENT_GOOGLE_SHEETS__ENABLED=false
JOB_AGENT_GOOGLE_SHEETS__SPREADSHEET_ID=your_google_sheet_id_here
JOB_AGENT_GOOGLE_SHEETS__CREDENTIALS_PATH=credentials/google_sheets_credentials.json

# --- Scheduler ---
JOB_AGENT_SCHEDULER__ENABLED=false
JOB_AGENT_SCHEDULER__SEARCH_TIME=08:00

# --- Browser ---
JOB_AGENT_BROWSER__STEALTH_MODE=true
JOB_AGENT_BROWSER__RUN_IN_BACKGROUND=false
